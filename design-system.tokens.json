{
  "meta": {
    "name": "GIS Portal Living Design System",
    "mode": "code-first-no-figma",
    "description": "Tokens and UI rules for the GIS Portal interface."
  },
  "colors": {
    "bg": "rgb(1, 1, 2)",
    "white": "#ffffff",
    "softWhite": "#f5f8ff",
    "ink": "#122238",
    "neutral900": "#121212",
    "text": "#ffffff",
    "textMuted": "#cccccc",
    "accent": "#f39200",
    "accentSoft": "rgba(243, 146, 0, 0.12)",
    "accentBorder": "rgba(243, 146, 0, 0.72)",
    "border": "#272727",
    "borderSoft": "rgba(245, 248, 255, 0.14)",
    "borderMuted": "rgba(245, 248, 255, 0.08)",
    "overlay": "rgba(1, 1, 2, 0.68)",
    "overlayMuted": "rgba(1, 1, 2, 0.58)"
  },
  "typography": {
    "headingFont": "UAF Sans",
    "bodyFont": "Montserrat",
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600
    },
    "tracking": {
      "eyebrow": "0.16em",
      "button": "0.02em"
    }
  },
  "layout": {
    "headerHeightDesktop": "72px",
    "headerHeightMobile": "64px",
    "containerXl": "1600px",
    "containerLg": "1120px"
  },
  "shape": {
    "radius": "0px",
    "borderWidth": "1px",
    "strongBorderWidth": "2px"
  },
  "spacing": [4, 8, 12, 16, 20, 24, 28, 32, 40, 48, 56, 64, 72, 96],
  "motion": {
    "fast": "160ms",
    "base": "240ms",
    "medium": "320ms",
    "standard": "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
    "outSoft": "cubic-bezier(0.22, 1, 0.36, 1)",
    "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
  }
}
